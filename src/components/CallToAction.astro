---
interface Props {
	href: string;
}

const { href } = Astro.props;
---

<a
	href={href}
	class="inline-flex items-center justify-center rounded-full bg-pink-700 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-pink-900/10 transition hover:bg-pink-800 sm:px-8 sm:py-4 sm:text-base"
>
	<slot />
</a>
