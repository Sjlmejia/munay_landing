---
const pathname = new URL(Astro.request.url).pathname;
const links = [
  { href: "/", label: "Inicio", match: "" },
  { href: "/general", label: "Faciales", match: "general" },
  { href: "/depilacion", label: "Depilación", match: "depilacion" },
  { href: "/reductores", label: "Reductores", match: "reductores" },
  { href: "/masajes", label: "Masajes", match: "masajes" },
  { href: "/contacto", label: "Contacto", match: "contacto" },
];

const isActive = (match: string) =>
  match === "" ? pathname === "/" : pathname.includes(match);
---

<header class="sticky top-0 z-50 border-b border-pink-100/80 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a class="flex items-center gap-3" href="/" aria-label="Munay Spa">
      <span class="sr-only">Home</span>
      <img class="h-12 w-auto" src="/ISOLOGO1.png" alt="Munay Spa" transition:name="munay-logo" />
      <span class="hidden text-sm font-semibold uppercase tracking-[0.25em] text-pink-700 sm:block">
        Munay
      </span>
    </a>

    <nav aria-label="Navegación principal" class="hidden items-center gap-1 rounded-full bg-pink-50 p-1 text-sm font-medium text-stone-600 lg:flex">
      {
        links.map((link) => (
          <a
            class:list={[
              "rounded-full px-4 py-2 transition",
              isActive(link.match)
                ? "bg-white text-pink-700 shadow-sm"
                : "hover:bg-white/70 hover:text-pink-700",
            ]}
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <a
      class="hidden rounded-full bg-pink-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-pink-800 sm:inline-flex"
      href="https://wa.me/593985706945"
      target="_blank"
      rel="noreferrer"
    >
      Reservar cita
    </a>

    <details class="relative lg:hidden">
      <summary class="flex cursor-pointer list-none items-center rounded-full border border-pink-200 px-4 py-2 text-sm font-semibold text-pink-800">
        Menú
      </summary>
      <div class="absolute right-0 mt-3 w-64 overflow-hidden rounded-2xl border border-pink-100 bg-white p-2 shadow-xl">
        {
          links.map((link) => (
            <a
              class:list={[
                "block rounded-xl px-4 py-3 text-sm font-medium",
                isActive(link.match)
                  ? "bg-pink-50 text-pink-700"
                  : "text-stone-700 hover:bg-pink-50",
              ]}
              href={link.href}
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </details>
  </div>
</header>
