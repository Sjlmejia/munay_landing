---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

const services = [
  {
    title: "Tratamientos faciales",
    text: "Limpiezas profundas, protocolos anti-acné y cuidado antiedad para renovar la piel.",
    href: "/general",
    image: "/tratamientos/limpieza1.jpeg",
  },
  {
    title: "Depilación",
    text: "Opciones faciales y corporales con atención cuidadosa para cada zona.",
    href: "/depilacion",
    image: "/depilacion/de2.webp",
  },
  {
    title: "Masajes",
    text: "Masajes relajantes y apoyo postoperatorio para liberar tensión y mejorar bienestar.",
    href: "/masajes",
    image: "/masajes/ma1.webp",
  },
  {
    title: "Reductores",
    text: "Protocolos corporales con drenaje, radiofrecuencia, carboxi y masaje manual.",
    href: "/reductores",
    image: "/reductores/re2.jpeg",
  },
];

const values = [
  "Evaluación personalizada",
  "Protocolos de higiene",
  "Productos seleccionados",
  "Acompañamiento cercano",
];
---

<Layout title="Munay Spa | Estética profesional en Loja" description="Spa y centro estético en Loja con tratamientos faciales, depilación, masajes y protocolos reductores.">
  <Hero />

  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-pink-700">Servicios</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-stone-950 sm:text-4xl">
          Tratamientos diseñados para tu piel y tu bienestar.
        </h2>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          services.map((service) => (
            <a class="group overflow-hidden rounded-2xl border border-pink-100 bg-pink-50/60 transition hover:-translate-y-1 hover:bg-white hover:shadow-xl hover:shadow-pink-950/10" href={service.href}>
              <img class="h-48 w-full object-cover transition duration-500 group-hover:scale-105" src={service.image} alt={service.title} />
              <div class="p-5">
                <h3 class="text-lg font-semibold text-stone-950">{service.title}</h3>
                <p class="mt-2 text-sm leading-6 text-stone-600">{service.text}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-pink-50 py-16 sm:py-20">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-pink-700">Munay</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-stone-950 sm:text-4xl">
          Un espacio para cuidarte con calma, criterio y detalle.
        </h2>
        <p class="mt-5 text-base leading-8 text-stone-600">
          Nuestro enfoque combina experiencia estética, trato humano y rutinas
          claras para que cada sesión tenga un objetivo concreto: limpiar,
          relajar, recuperar o moldear según lo que necesitas.
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {values.map((value) => <p class="rounded-full bg-white px-4 py-3 text-sm font-semibold text-pink-800 shadow-sm">{value}</p>)}
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <img class="h-64 w-full rounded-2xl object-cover sm:h-80" src="/sandra.jpg" alt="Sandra Mejía" />
        <img class="mt-10 h-64 w-full rounded-2xl object-cover sm:h-80" src="/jaky.jpg" alt="Jackeline Macas" />
      </div>
    </div>
  </section>
</Layout>
