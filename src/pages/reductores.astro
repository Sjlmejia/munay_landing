---
import Layout from "../layouts/Layout.astro";
import TratamientoCard from "../components/TratamientoCard.astro";

const tratamientos = [
  {
    price: "$30",
    title: "L masaje manual + drenaje lim + manta térmica",
    img: "/reductores/re1.jpeg",
  },
  {
    price: "$30",
    title: "M masaje manual + radiofrecuencia + carboxi",
    img: "/reductores/re2.jpeg",
  },
  {
    price: "$30",
    title: "V masaje manual + radiofrecuencia + carboxi",
    img: "/reductores/re3.jpeg",
  },
  {
    price: "$20",
    title: "Drenaje linfático",
    img: "/reductores/re4.jpeg",
  },
];
---

<Layout title="Tratamientos reductores | Munay Spa">
  <section class="bg-pink-50 py-14 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-pink-700">Corporales</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-stone-950 sm:text-5xl">Tratamientos reductores</h1>
        <p class="mt-5 text-base leading-8 text-stone-600">Sesiones corporales con masaje manual, drenaje y aparatología según el objetivo del protocolo.</p>
      </div>
    </div>
  </section>
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
    {
      tratamientos.map((tratamiento) => (
        <TratamientoCard
          price={tratamiento.price}
          title={tratamiento.title}
          image={tratamiento.img}
        />
      ))
    }
    </div>
  </section>
</Layout>
