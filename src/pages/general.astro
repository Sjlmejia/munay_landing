---
import Layout from "../layouts/Layout.astro";
import TratamientoCard from "../components/TratamientoCard.astro";

const tratamientos = [
  {
    price: "$30",
    title: "Limpieza facial profunda",
    img: "/tratamientos/limpieza1.jpeg",
    description: 'La limpieza facial profunda es un procedimiento de mantenimiento que elimina todas las impurezas que se encuentran en la piel generadas por el mismo cuerpo.'
  },
  {
    price: "$35",
    title: "LFP con microdermoabrasión",
    img: "/tratamientos/tra2.jpeg",
    description: 'La microdermoabrasión es un procedimiento estético que consiste en la exfoliación de la piel para eliminar las células muertas y promover la regeneración celular.'
  },
  {
    price: "$150",
    title: "TTO anti-acné 5 sesiones",
    img:  "/tratamientos/tra3.png",
    description: 'El tratamiento anti-acné es un procedimiento que se realiza para eliminar las impurezas de la piel y así evitar la aparición de acné.'
  },
  {
    price: "$250",
    title: "TTO anti-arrugas 10 sesiones",
    img:  "/tratamientos/tra4.webp",
    description: 'El tratamiento anti-arrugas es un procedimiento que se realiza para eliminar las impurezas de la piel y así evitar la aparición de arrugas.'
  },
  {
    price: "$100",
    title: "Párpados 6 sesiones, Drenaje linfático, Radiofrecuencia y Carboxi",
    img:  "/tratamientos/tra5.webp",
    description: 'El tratamiento de párpados es un procedimiento que se realiza para eliminar las impurezas de la piel y así evitar la aparición de arrugas.'
  },
  {
    price: "$15 x sesion",
    title: "Drenaje facial postoperatorio",
    img:  "/tratamientos/tra6.jpeg",
    description: 'El drenaje facial postoperatorio es un procedimiento que se realiza para eliminar las impurezas de la piel y así evitar la aparición de arrugas.'
  },
];
---

<Layout title="Tratamientos faciales | Munay Spa">
  <section class="bg-pink-50 py-14 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-pink-700">Faciales</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-stone-950 sm:text-5xl">Tratamientos generales</h1>
        <p class="mt-5 text-base leading-8 text-stone-600">Protocolos para limpiar, renovar y acompañar las necesidades de tu piel con atención personalizada.</p>
      </div>
    </div>
  </section>
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-3 lg:px-8">
    {
      tratamientos.map((tratamiento) => (
        <TratamientoCard
          price={tratamiento.price}
          title={tratamiento.title}
          image={tratamiento.img}
          description={tratamiento.description}
        />
      ))
    }
    </div>
  </section>
</Layout>
