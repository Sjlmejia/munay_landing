---
import Layout from "../layouts/Layout.astro";
import TratamientoCard from "../components/TratamientoCard.astro";

const tratamientos = [
  {
    price: "$45",
    title: "Masaje relajante Completo",
    img: "/masajes/ma1.webp",
    description: "Masaje relajante completo ",
  },
  {
    price: "$25",
    title: "Masaje relajante Parcial",
    img: "/masajes/ma2.jpeg",
    description: "Masaje relajante parcial",
  },
  {
    price: "",
    title: "Paquetes de mantenimiento post-operatorio",
    img: "/masajes/ma3.jpeg",
    description: "Paquetes de mantenimiento post-operatorio",
  },
];
---

<Layout title="Masajes | Munay Spa">
  <section class="bg-pink-50 py-14 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-pink-700">Bienestar</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-stone-950 sm:text-5xl">Masajes</h1>
        <p class="mt-5 text-base leading-8 text-stone-600">Espacios para relajar el cuerpo, liberar tensión y acompañar procesos postoperatorios con cuidado profesional.</p>
      </div>
    </div>
  </section>
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-3 lg:px-8">
    {
      tratamientos.map((tratamiento) => (
        <TratamientoCard
          price={tratamiento.price}
          title={tratamiento.title}
          image={tratamiento.img}
          description={tratamiento.description}
        />
      ))
    }
    </div>
  </section>
</Layout>
