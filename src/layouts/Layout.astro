---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Centro de estética y SPA en Loja, Ecuador." } = Astro.props;
---

<!doctype html>
<html lang="es">
  <BaseHead title={title} description={description} />
  <body class="min-h-screen bg-pink-50 text-stone-900 antialiased">
    <Header />
    <main transition:name="page-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
